# ──────────────────────────────────────────────────────────────────────────
# Unbored configuration — EVERYTHING here is optional.
#
# With no keys at all, Unbored runs in demo mode: a bundled offline catalog
# plus hand-written "Why now?" sentences. Add keys to upgrade the experience.
# Copy this file to `.env` (the setup script does this for you).
# ──────────────────────────────────────────────────────────────────────────

# ── Catalog (movies / TV) ─────────────────────────────────────────────────
# A free TMDB key switches from the offline demo catalog to the live one
# (thousands of titles, fresh trending). Get one at:
# https://www.themoviedb.org/settings/api  (use the API Read Access Token)
TMDB_API_KEY=

# ── LLM for "Why now?" sentences ──────────────────────────────────────────
# Provider selection. "auto" (default) uses the first provider below that has
# a key, in order: gemini → deepseek → openai → openrouter. Force one by name
# (gemini | deepseek | openai | openrouter), or "none" to always use the
# built-in offline sentences.
LLM_PROVIDER=auto

# Google Gemini — free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (or any OpenAI-compatible endpoint) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # point at Groq/Together/Ollama/etc.

# OpenRouter — one key, many models: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── Server (sensible defaults; rarely need changing) ──────────────────────
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173
# LOG_LEVEL=INFO
